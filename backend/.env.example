# JWT Authentication Secret
JWT_SECRET=your-jwt-secret-here

# SMTP CONFIG (To send real emails to departments)
# For Gmail: Use your email and an "App Password" (not your regular login password)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here

# OPENAI_API_KEY (Optional — enables real Whisper STT. Without it, mock transcriptions are used.)
OPENAI_API_KEY=sk-proj-your-api-key-here

# Escalation Config
# SUPERVISOR_EMAIL=supervisor@tn.gov.in
# DIGEST_RECIPIENT=admin@tn.gov.in
# HUMAN_AGENT_QUEUE=complaint-support

# ─── Public server URL (ngrok or production HTTPS) ───────────────────────────
# This is sent back in ExoML/TwiML so Exotel/Twilio can reach subsequent steps.
# Run: ngrok http 5000  →  copy the https URL below (no trailing slash)
SERVER_URL=https://your-ngrok-url-here.ngrok-free.dev

# ─── Twilio Voice API ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# ─── Exotel API ───────────────────────────────────────────────────────────────
# Get credentials from: https://my.exotel.com/apisettings/sandbox
# Webhook URL to set in Exotel dashboard → Exophone → "When a call comes in":
#   POST  https://<your-ngrok-url>/api/exotel/incoming
#
EXOTEL_ACCOUNT_SID=your-exotel-account-sid-here
EXOTEL_API_KEY=your-exotel-api-key-here
EXOTEL_API_TOKEN=your-exotel-api-token-here
EXOTEL_EXOPHONE=080-XXXX-XXXX
